# ============================================================
# AI Forex Trading System — Environment Configuration
# Copy file ini ke .env dan isi nilainya
# JANGAN commit .env ke git
# ============================================================

# --- MT5 Connection ---
MT5_LOGIN=123456789
MT5_PASSWORD=your_password_here
MT5_SERVER=YourBroker-Server
MT5_PATH=

# --- Trading Settings ---
DEFAULT_PAIR=XAUUSDm
DEFAULT_TF=M15
DEFAULT_CANDLES=100
INTERVAL_MINUTES=15
DRY_RUN=true

# --- LLM Provider ---
LLM_PROVIDER=openai
LLM_MODEL=gpt-4o
OPENAI_API_KEY=sk-...
# ANTHROPIC_API_KEY=sk-ant-...

# --- Memory & Storage ---
FORMULA_PATH=./config/formula.yaml
PAIRS_CONFIG=./config/pairs.yaml
DB_PATH=./data/trades.db
VECTOR_DIR=./data/chromadb

# --- Adaptive Learning ---
LEARN_EVERY_N=10

# --- MT5 Magic Number ---
MT5_MAGIC=20260325

# --- Telegram Notifications ---
TELEGRAM_BOT_TOKEN=your_bot_token_here
TELEGRAM_CHAT_ID=your_chat_id_here

# --- Groq (FREE alternative) ---
# GROQ_API_KEY=gsk_...
# LLM_PROVIDER=groq
# LLM_MODEL=llama-3.3-70b-versatile

# --- Browser Provider Settings (Playwright — no API key needed) ---
# LLM_PROVIDER=browser_chatgpt   # or browser_claude, api_anthropic, api_openai
CHATGPT_EMAIL=your_email@gmail.com
CHATGPT_PASSWORD=your_password
CLAUDE_EMAIL=your_email@gmail.com
CLAUDE_PASSWORD=your_password
BROWSER_HEADLESS=false
BROWSER_SESSION_DIR=data/sessions

# ============================================================
# AI Forex Trading System — Environment Variables
# Copy ke .env dan isi dengan nilai sebenarnya
# JANGAN commit .env ke git
# ============================================================

# -- MetaTrader5 ---------------------------------------------
MT5_LOGIN=12345678
MT5_PASSWORD=your_mt5_password
MT5_SERVER=YourBroker-Demo
# MT5_PATH=C:\Program Files\MetaTrader 5\terminal64.exe
MT5_MAGIC=20260325

# -- LLM Provider --------------------------------------------
# anthropic atau openai
LLM_PROVIDER=openai

OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o

# ANTHROPIC_API_KEY=sk-ant-...
# ANTHROPIC_MODEL=claude-opus-4-6

# -- Trading Settings ----------------------------------------
DEFAULT_PAIR=EURUSD
DEFAULT_TF=M15
DEFAULT_CANDLES=100
INTERVAL_MINUTES=15

# DRY_RUN=true  -> tidak ada order nyata
# DRY_RUN=false -> live trading
DRY_RUN=true

# -- Memory & Storage ----------------------------------------
FORMULA_PATH=./config/formula.yaml
DB_PATH=./data/trades.db
VECTOR_DIR=./data/chromadb

# -- Adaptive Learning ---------------------------------------
LEARN_EVERY_N=10
